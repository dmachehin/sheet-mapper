{
  "name" : "dmachehin/sheet-mapper",
  "description": "Map spreadsheet rows to structured PHP data objects",
  "authors": [
    {
      "name": "Dmitriy Machehin",
      "email": "raiderz@gmail.com"
    }
  ],
  "keywords": [
    "sheet",
    "spreadsheet",
    "mapper"
